{
  "name": "@weer/server",
  "version": "1.0.0",
  "description": "URL Shortner Application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "seed": "./env.sh tsx ./src/database/seed.ts",
    "test": "./env.sh tsx ../../node_modules/mocha/bin/_mocha --extension ts \"__tests__/**/*.test.ts\" --timeout 10000",
    "dev": "./env.sh tsx watch ./src/index.ts",
    "dev-inspect": "./env.sh tsx --inspect ./src/index.ts",
    "janitor": "./env.sh tsx ./src/janitor.ts",
    "build": "rm -rf ./dist && tsc -p .",
    "start": "./env.sh node ./dist/index.js",
    "cluster-dev": "./env.sh tsx ./src/cluster.ts",
    "prod": "./env.sh pm2 start ecosystem.config.cjs"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/qrcode": "^1.5.5",
    "@weer/common": "1.0.0",
    "compression": "^1.7.4",
    "cpeak": "2.8.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/mocha": "^10.0.10",
    "@types/mysql": "^2.15.27",
    "@types/node": "^24.5.1",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "mocha": "^11.7.2",
    "supertest": "^4.0.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
