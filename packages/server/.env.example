# This is an example .env file for the server. You should copy this to .env and fill in the values as needed.

PORT='2080'
DOMAIN='http://localhost:2080'

# OPTIONAL: if you don't want to set the google client ID and secret, you won't be able to log in with Google, but you can still use the app.
# Grab these from the Google Cloud Console by setting up your OAuth credentials here: https://console.cloud.google.com/apis/credentials 
# Make sure to set the authorized redirect URI to http://localhost:2080/auth/google/callback.
GOOGLE_CLIENT_ID='<generate-your-own>.apps.googleusercontent.com'
GOOGLE_CLIENT_SECRET='<grab-from-google-cloud-console>'

COOKIE_KEY='<random-at-least-32-characters>'
REDIS_URL='redis://127.0.0.1:6379'
REDIS=false # set this to false if you don't want to use Redis (not recommended, as the janitor won't work and views won't be processed)

# These can be left as if if running with Docker
DB_USER='postgres' # change this to your PostgreSQL username
DB_HOST='localhost'
DB_DATABASE='weer'
DB_PASSWORD=''
DB_PORT='5432'